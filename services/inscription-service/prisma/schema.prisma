generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model InscripcionPonencia {
  id            String    @id @default(uuid())
  usuarioId     String
  ponenciaId    String
  asistio       Boolean   @default(false)
  fecha_inscripcion DateTime @default(now())

  usuario       Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  ponencia      Ponencia  @relation(fields: [ponenciaId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, ponenciaId])
}

// Stubs for cross-service relations to allow Prisma generation
model Usuario {
  id           String @id
  inscripciones InscripcionPonencia[]
}

model Ponencia {
  id           String @id
  inscripciones InscripcionPonencia[]
}