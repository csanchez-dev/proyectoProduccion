generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Evento {
  id          String     @id @default(uuid())
  nombre      String
  descripcion String?
  fecha_inicio DateTime
  fecha_fin    DateTime
  creado_en   DateTime   @default(now())
  dias        DiaEvento[]
}

model DiaEvento {
  id       String    @id @default(uuid())
  fecha    DateTime
  evento   Evento    @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  eventoId String
  ponencias Ponencia[]
}

model Sala {
  id       String @id @default(uuid())
  nombre   String
  capacidad Int
  ubicacion String?
  ponencias Ponencia[]
}

model Ponencia {
  id           String     @id @default(uuid())
  diaEvento    DiaEvento  @relation(fields: [diaEventoId], references: [id], onDelete: Cascade)
  diaEventoId  String
  sala         Sala       @relation(fields: [salaId], references: [id])
  salaId       String
  titulo       String
  descripcion  String?
  hora_inicio  DateTime
  hora_fin     DateTime
  cupo_maximo  Int
  estado       String     @default("programada")
  ponentes     PonenciaPonente[]
  inscripciones InscripcionPonencia[]
}

model Ponente {
  id          String @id @default(uuid())
  nombres     String
  apellidos   String
  biografia   String?
  email       String?
  organizacion String?
  ponencias   PonenciaPonente[]
}

model PonenciaPonente {
  ponencia   Ponencia @relation(fields: [ponenciaId], references: [id], onDelete: Cascade)
  ponenciaId String
  ponente    Ponente  @relation(fields: [ponenteId], references: [id], onDelete: Cascade)
  ponenteId  String

  @@id([ponenciaId, ponenteId])
}