# =============================================================
# PLANTILLA DE VARIABLES DE ENTORNO — CONIITI PROJECT
# =============================================================
# IMPORTANTE: Copia este archivo como `.env` y completa los
# valores REALES. Nunca subas el archivo `.env` al repositorio.
# =============================================================

# ─── BASE DE DATOS (PostgreSQL) ───────────────────────────────
# CAMBIAR OBLIGATORIAMENTE antes de producción.
# NO usar "postgres"/"postgres" en entornos expuestos a internet.
DB_USER=postgres
DB_PASSWORD=CAMBIAR_POR_CONTRASENA_SEGURA

# ─── JWT ──────────────────────────────────────────────────────
# Mínimo 32 caracteres aleatorios. Generar con:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIAR_POR_SECRETO_JWT_MUY_LARGO_Y_ALEATORIO

# ─── CORS ─────────────────────────────────────────────────────
# Lista de orígenes permitidos separados por coma.
# En producción, reemplazar con el dominio real del frontend.
# Ejemplo: https://coniiti.ucatolica.edu.co
ALLOWED_ORIGINS=http://localhost:5173,http://localhost

# ─── RABBITMQ ─────────────────────────────────────────────────
# CAMBIAR las credenciales por defecto antes de exponer en producción.
RABBITMQ_USER=CAMBIAR_USUARIO_RABBITMQ
RABBITMQ_PASS=CAMBIAR_CONTRASENA_RABBITMQ

# ─── GRAFANA / MONITOREO ──────────────────────────────────────
# Contraseña del panel de administración de Grafana.
GRAFANA_PASSWORD=CAMBIAR_CONTRASENA_GRAFANA

# ─── SUPABASE (si se usa) ─────────────────────────────────────
# Usar la clave de servicio (service_role key) solo en el servidor,
# NUNCA en el cliente frontend.
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu_anon_key_publica
# SUPABASE_SERVICE_KEY=tu_service_key_SOLO_en_backend
